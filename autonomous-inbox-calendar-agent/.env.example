# Copy to .env (or set as Replit Secrets) and fill in.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# Rube MCP endpoint + bearer token. Get these from https://rube.app after
# signing in and connecting Gmail, Google Calendar, Outlook, and Slack.
RUBE_MCP_URL=https://rube.app/mcp
RUBE_MCP_TOKEN=

# --- Model ---
# Defaults to Sonnet 4.6 (cheaper for an always-on loop). Swap to
# claude-opus-4-7 if you want stronger reasoning per tick.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Loop ---
# Seconds between ticks. 60 is a reasonable floor; lower = more API spend.
POLL_INTERVAL_SECONDS=60

# --- Safety rails ---
# DRY_RUN=1 means the agent plans actions but is instructed NOT to send,
# reply, archive, accept, or decline anything. Drafts/labels only.
DRY_RUN=0

# Path to a kill-switch file. If this file exists, the loop sleeps
# instead of calling the model. Create it to pause the agent instantly:
#   touch PAUSE
KILL_SWITCH_FILE=PAUSE

# Max actions per tick (defensive cap so a runaway tool-use loop can't
# send 500 emails). The agent is told this budget in the system prompt.
MAX_ACTIONS_PER_TICK=12

# Comma-separated list of your own email addresses. The agent will never
# send mail TO these (prevents self-loops) and treats calendar invites
# from these as authoritative.
OWNER_EMAILS=you@example.com

# Optional: comma-separated allowlist of domains/emails that the agent
# is allowed to reply to without flagging. Empty = agent uses its own
# judgment (fully autonomous mode).
REPLY_ALLOWLIST=

# On the very first tick (no memory yet) the agent will only look at items
# from this many minutes back — prevents it from trying to triage weeks of
# backlog on cold start. After that, memory from previous ticks bounds the
# window.
FIRST_RUN_LOOKBACK_MINUTES=60

# Label applied to mail threads the agent has already handled. Used as the
# primary dedupe signal across overlapping ticks — the agent is told to
# exclude anything carrying this label.
HANDLED_LABEL=agent/handled

# Extended thinking budget (tokens). 0 disables it (default — cheapest,
# fine for routine triage). Set to 5000-10000 to improve multi-calendar
# scheduling negotiation quality. Note: changing this invalidates the
# prompt cache, so keep it stable across ticks.
THINKING_BUDGET_TOKENS=0
